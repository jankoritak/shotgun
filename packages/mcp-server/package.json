{
  "name": "@shotgun/mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "stdio MCP server exposing Shotgun's write-only X post tools. Wraps @shotgun/core.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "shotgun-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@shotgun/core": "workspace:*",
    "zod": "^3.23.0"
  }
}
