# Shotgun BYOK credentials — copy to `.env` and fill in, or export these in your shell.
# `.env` is gitignored; only this example is committed. Never commit real keys.
#
# Get all four from the X Developer Portal (https://developer.x.com):
#   1. Create a project + app.
#   2. User authentication settings -> permissions = Read and Write.
#   3. Generate the 4 OAuth 1.0a credentials (regenerate Access tokens AFTER
#      enabling write, so they carry write scope).

SHOTGUN_X_API_KEY=
SHOTGUN_X_API_SECRET=
SHOTGUN_X_ACCESS_TOKEN=
SHOTGUN_X_ACCESS_SECRET=

# Optional. When unset, Shotgun runs live IF all four keys above are present,
# and falls back to dry-run automatically when any key is missing. Set to 1 to
# force dry-run (render without posting) even with valid keys — useful for demos.
# SHOTGUN_DRY_RUN=1
