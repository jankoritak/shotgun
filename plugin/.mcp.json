{
  "mcpServers": {
    "bullhorn": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bin/mcp-server.js"],
      "env": {
        "BULLHORN_X_API_KEY": "${BULLHORN_X_API_KEY}",
        "BULLHORN_X_API_SECRET": "${BULLHORN_X_API_SECRET}",
        "BULLHORN_X_ACCESS_TOKEN": "${BULLHORN_X_ACCESS_TOKEN}",
        "BULLHORN_X_ACCESS_SECRET": "${BULLHORN_X_ACCESS_SECRET}",
        "BULLHORN_DRY_RUN": "${BULLHORN_DRY_RUN}"
      }
    }
  }
}
